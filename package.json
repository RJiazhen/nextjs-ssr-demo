  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^20.19.41",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "15.5.18",
    "sass": "^1.99.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.90.1"
  },
  "volta": {
    "node": "22.14.0"
